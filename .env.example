# ─────────────────────────────────────────────────────────────────────────────
# QueueUp environment variables
#
# Copy to `.env.local` for local dev and fill in real values. NEVER commit a file
# with real secrets — `.env*` is git-ignored (except this example).
# Only `VITE_`-prefixed vars are exposed to the browser; keep server-only secrets
# (service role key, Sentry auth token) out of this client app and in the platform
# secret stores (Supabase / Vercel) instead.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (Project Settings → API) ---
# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=
# Publishable "anon" key (safe for the browser; RLS enforces access)
VITE_SUPABASE_ANON_KEY=

# --- Clerk (Dashboard → API Keys) ---
# Publishable key, starts with pk_test_ or pk_live_
VITE_CLERK_PUBLISHABLE_KEY=

# --- App ---
# Public site URL (used for absolute QR/join links). e.g. https://queueup.vercel.app
VITE_APP_URL=http://localhost:5173
# development | preview | production
VITE_ENV=development

# --- Observability (optional in dev) ---
# Sentry DSN for frontend error capture
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Edge-function / server-only secrets — set these in Supabase, NOT in this file.
# Listed here for documentation only:
#   SUPABASE_SERVICE_ROLE_KEY   server-side privileged DB access (edge functions)
#   ALLOWED_ORIGINS             comma-separated CORS allow-list (Section 9.3)
#   CLERK_SECRET_KEY            server-side Clerk verification (if used)
# ─────────────────────────────────────────────────────────────────────────────
